---
import Layout from '../../layouts/Layout.astro';
import { fetchNoteArticles } from '../../lib/note';

export async function getStaticPaths() {
  const articles = await fetchNoteArticles(100);
  return articles.map((article) => ({
    params: { key: article.key },
    props: { article }
  }));
}

const { article } = Astro.props;
---

<Layout
  title={`${article.title}｜げんき塾チーム`}
  description={article.body?.substring(0, 120) || `${article.title} - げんき塾チームからのお知らせです。`}
>
  <div class="seo-content">
    <article>
      <h1>{article.title}</h1>
      <time datetime={new Date(article.publishedAt).toISOString()}>
        {new Date(article.publishedAt).toLocaleDateString('ja-JP')}
      </time>
      {article.body && <div set:html={article.body} />}
      <p>
        <a href={article.noteUrl} target="_blank" rel="noopener noreferrer">
          noteで続きを読む
        </a>
      </p>
    </article>
  </div>
</Layout>

<style>
  .seo-content {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
</style>
