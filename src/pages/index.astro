---
import Layout from '../layouts/Layout.astro';
import { getEventsByMaxOrder } from '../lib/events';

const topEvents = getEventsByMaxOrder(3);
---

<Layout title="げんき塾チーム｜群馬県富岡市のイベント・お祭り企画" description="群馬県富岡市を拠点に活動する「げんき塾チーム」公式サイト。げんきフェスタをはじめ、地域を元気にするイベント・お祭りを企画運営。音楽、グルメ、ワークショップなど家族で楽しめるイベント情報を発信中。">
  <!-- SEO用コンテンツ（視覚的非表示、Googlebot向け） -->
  <div class="seo-content">
    <h1>げんき塾チーム - 群馬県富岡市のイベント・お祭り企画チーム</h1>
    <p>群馬県富岡市を拠点に活動する「げんき塾チーム」公式サイト。げんきフェスタをはじめ、地域を元気にするイベント・お祭りを企画運営。</p>
    <h2>主なイベント</h2>
    <ul>
      {topEvents.map((event) => (
        <li>
          <h3>{event.title}</h3>
          <p>{event.date}</p>
          <p>{event.description}</p>
        </li>
      ))}
    </ul>
  </div>
</Layout>

<style>
  .seo-content {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
</style>
